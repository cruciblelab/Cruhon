# @raw basic
@raw
x = [i**2 for i in range(4)]
print(x)
@end

# @raw with standard library
@raw
import math
print(math.factorial(5))
@end

# @raw inside @func
@func[squares; n]
    @raw
    result = [i**2 for i in range(n)]
    @end
    @return[result]
@end
@var[r; squares(4)]
@print[{r}]

@print[raw ok]
